rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /players/photos/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gallery/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /team/{file} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /players/ausweise/{file} {
      allow read, write: if request.auth != null;
    }
  }
}
